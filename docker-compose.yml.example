services:
  audiobooks_green_proxy:
    image: ghcr.io/fabrikant/audiobooks_green_proxy:latest
    container_name: audiobooks_green_proxy
    ports:
      - "8081:8081"
    environment:
      # Если true, то по пути http[s]://server:port/docs будет доступен Swagger
      - SHOW_SWAGGER=false
      #    Uvicorn принимает следующие варианты для параметра --log-level:
      # • critical (самый высокий уровень, только критические ошибки)
      # • error (ошибки)
      # • warning (предупреждения)
      # • info (информационные сообщения, значение по умолчанию)
      # • debug (отладочные сообщения)
      # • trace (очень подробные отладочные сообщения, включая тела запросов/ответов, добавленный в последних версиях Uvicorn)
      # В зависимости от этой переменной также устанавливаются логи всего приложения
      - LOG_LEVEL=warning

      # *****************************************************************************
      # Переменный для инициализации телеграм бота.
      # Опционально
      # Если переменные не установлены, бот не будет запущен. Будет работать только http прокси
      # Получить на https://my.telegram.org
      - TELEGRAM_API_ID=
      - TELEGRAM_API_HASH=
      # Получить у бота https://t.me/BotFather
      - TELEGRAM_BOT_TOKEN=
      # Идентификатор телеграмм. Нужно ввести идентификатор для того, чтобы назначить
      # админа этого бота. Узнать ID можно запустив этого бота без указания админа
      # и выполнив команду /start
      # Также можно воспользоваться кучей другиз ботов
      - TELEGRAM_ADMIN_ID=

      # *****************************************************************************
      # Опционально. Для работы без обратного прокси.
      # Файлы должны располагаться в папке /app/data приложения. Другими словами в
      # volume контейнера
      # - SSL_CERT_FILE=/app/data/fullchain.pem
      # - SSL_PRIVATE_KEY_FILE=/app/data/priv.pem
    restart: unless-stopped
